# ml_models research output not used by the app at runtime.
# AdvancedEnsembleBackend only reads 12 files from ml_models/models/:
#   training_results.json, advanced_nn_results.json, feature_columns.json,
#   scaler.pkl, lightgbm_model.txt, xgboost_model.json,
#   catboost_model{1,2,3}.cbm, neural_network_model.pkl,
#   nn_alfa_model.pt, nn_lstm_transformer_model.pt
